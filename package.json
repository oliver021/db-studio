{
  "name": "sqlite-nav",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "build:preload": "esbuild electron/preload.cts --outfile=dist-electron/preload.cjs --platform=node --format=cjs",
    "dev": "npm run build:preload && vite",
    "build": "npm run build:preload && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed": "node scripts/seed-db.js",
    "seed:crm": "node scripts/seed-crm.js",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky",
    "test": "vitest run",
    "test:unit": "vitest run --project node",
    "test:components": "vitest run --project browser",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "docs:gen": "typedoc"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "vitest related --run"],
    "*.{js,json,css,md}": ["prettier --write"]
  },
  "dependencies": {
    "@heroui/pagination": "^2.2.27",
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "@monaco-editor/react": "^4.7.0",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.12",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.0.0",
    "typedoc": "^0.28.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.sqlitenav.app",
    "productName": "SQLiteNav",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "icon": "build/icon.png",
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "license": "LICENSE.txt"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
